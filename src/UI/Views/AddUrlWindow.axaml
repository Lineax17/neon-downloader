<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UI.ViewModels"
        x:Class="UI.Views.AddUrlWindow"
        x:DataType="vm:AddUrlWindowViewModel"
        Title="URL hinzufügen"
        Width="400" Height="200"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:AddUrlWindowViewModel/>
    </Design.DataContext>

    <StackPanel Margin="20" Spacing="10">
        <TextBox Text="{Binding Url}" Watermark="Paste Url..."/>
        <Button Content="Add" Command="{Binding ConfirmCommand}"/>
    </StackPanel>

</Window>
